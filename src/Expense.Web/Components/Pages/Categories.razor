@page "/categories"
@using Expense.Domain.Entities
@using Expense.Domain.Services.Categories
@inject ICategoriesPageProvider CategoriesProvider

<PageTitle>Categories</PageTitle>

<h1>Categories</h1>

@if (_data is null)
{
    <p>Loading...</p>
}
else
{
    <div style="display:flex; gap:2rem; align-items:flex-start;">
        <div style="flex:1;">
            <div>
                <input id="category-filter" placeholder="Filter by name..." value="@_filterText"
                       @oninput="e => _filterText = (string)e.Value!" />
                <button id="new-category-button" @onclick="StartCreating">+ New Category</button>
            </div>
            <table>
                <thead>
                    <tr>
                        <th @onclick='() => Sort("Name")' style="cursor:pointer;">Name</th>
                        <th @onclick='() => Sort("Funding")' style="cursor:pointer;">Funding strategy</th>
                        <th>Direction</th>
                        <th>Amount</th>
                        <th>Frequency</th>
                        <th @onclick='() => Sort("Status")' style="cursor:pointer;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in VisibleCategories())
                    {
                        var columns = BudgetColumns(category);
                        <tr @key="category.Id" id="category-row-@category.Id" @onclick="() => SelectAsync(category)"
                            style="cursor:pointer; @(category.Id == _selectedId ? "font-weight:bold;" : "")">
                            <td>@category.Name</td>
                            <td>@FundingStrategyLabel(category.FundingStrategy)</td>
                            <td>@columns.Direction</td>
                            <td>@columns.Amount</td>
                            <td>@columns.Frequency</td>
                            <td>@(category.IsActive ? "Active" : "Inactive")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div style="flex:1;">
            @if (_mode == DetailMode.None)
            {
                <p>Select a category on the left to edit it, or click "New Category" to create one.</p>
            }
            else
            {
                <h2>@(_mode == DetailMode.Creating ? "New category" : "Edit category")</h2>
                <div>
                    <label>Name <input id="detail-name" value="@_formName" @onchange="e => _formName = (string)e.Value!" /></label>
                </div>
                <div>
                    <label>Funding strategy
                        <select id="detail-funding-strategy" @onchange="e => _formFundingStrategy = (string)e.Value!">
                            <option value="@FundingStrategies.None" selected="@(_formFundingStrategy == FundingStrategies.None)">None</option>
                            <option value="@FundingStrategies.PayInFullAmex" selected="@(_formFundingStrategy == FundingStrategies.PayInFullAmex)">Pay in full (Amex)</option>
                            <option value="@FundingStrategies.Direct" selected="@(_formFundingStrategy == FundingStrategies.Direct)">Direct (recurring income/bill)</option>
                            <option value="@FundingStrategies.AccountPayment" selected="@(_formFundingStrategy == FundingStrategies.AccountPayment)">Account payment (debt account)</option>
                        </select>
                    </label>
                </div>
                @if (_formFundingStrategy == FundingStrategies.AccountPayment)
                {
                    @if (_formLinkedAccountType is { } linkedType)
                    {
                        @if (linkedType == AccountType.Debt)
                        {
                            <div>
                                <label>Min payment
                                    <input id="detail-min-payment" type="number" step="0.01" value="@_formMinPayment"
                                           @onchange="e => _formMinPayment = ParseNullableDecimal((string)e.Value!)" />
                                </label>
                            </div>
                        }
                        <div>
                            <label>Extra payment
                                <input id="detail-extra-payment" type="number" step="0.01" value="@_formExtraPayment"
                                       @onchange="e => _formExtraPayment = ParseNullableDecimal((string)e.Value!)" />
                            </label>
                        </div>
                        <div>
                            <label>Payment due day
                                <input id="detail-payment-due-day" type="number" value="@_formPaymentDueDay"
                                       @onchange="e => _formPaymentDueDay = ParseNullableInt((string)e.Value!)" />
                            </label>
                        </div>
                        @if (linkedType == AccountType.ActiveSpending)
                        {
                            <div>
                                <label>Statement close day
                                    <input id="detail-statement-close-day" type="number" value="@_formStatementCloseDay"
                                           @onchange="e => _formStatementCloseDay = ParseNullableInt((string)e.Value!)" />
                                </label>
                            </div>
                        }
                    }
                    else
                    {
                        <p><em>This category has no linked account yet - account payment categories are normally created automatically from the Accounts page.</em></p>
                    }
                }
                @if (_formFundingStrategy == FundingStrategies.Direct)
                {
                    <div>
                        <label>Direction
                            <select id="detail-direction" @onchange="e => _formDirection = Enum.Parse<Direction>((string)e.Value!)">
                                @foreach (var direction in Enum.GetValues<Direction>())
                                {
                                    <option value="@direction" selected="@(_formDirection == direction)">@direction</option>
                                }
                            </select>
                        </label>
                    </div>
                }
                @if (_formFundingStrategy == FundingStrategies.Direct || _formFundingStrategy == FundingStrategies.PayInFullAmex)
                {
                    <div>
                        <label>Amount
                            <input id="detail-amount" type="number" step="0.01" value="@_formAmount"
                                   @onchange="e => _formAmount = decimal.Parse((string)e.Value!)" />
                        </label>
                    </div>
                    <div>
                        <label>Frequency
                            <select id="detail-frequency" @onchange="e => _formFrequency = Enum.Parse<Frequency>((string)e.Value!)">
                                @foreach (var frequency in Enum.GetValues<Frequency>())
                                {
                                    <option value="@frequency" selected="@(_formFrequency == frequency)">@frequency</option>
                                }
                            </select>
                        </label>
                    </div>
                }
                @if (_formFundingStrategy == FundingStrategies.Direct)
                {
                    <div>
                        <label>Anchor date
                            <input id="detail-anchor" type="date" value="@_formAnchor.ToString("yyyy-MM-dd")"
                                   @onchange="e => _formAnchor = DateOnly.Parse((string)e.Value!)" />
                        </label>
                    </div>
                    <div>
                        <label>Account
                            <select id="detail-account" @onchange="e => _formAccountId = int.Parse((string)e.Value!)">
                                <option value="">Select an account...</option>
                                @foreach (var account in _data!.Accounts)
                                {
                                    <option value="@account.Id" selected="@(_formAccountId == account.Id)">@account.Name</option>
                                }
                            </select>
                        </label>
                    </div>
                }
                <button id="detail-save" @onclick="SaveAsync">Save</button>
                @if (_mode == DetailMode.Editing)
                {
                    @if (_selectedIsActive)
                    {
                        <button id="detail-deactivate" @onclick="DeactivateAsync">Deactivate</button>
                    }
                    else
                    {
                        <button id="detail-reactivate" @onclick="ReactivateAsync">Reactivate</button>
                    }
                }
            }
        </div>
    </div>
}

@code {
    private enum DetailMode { None, Editing, Creating }

    private CategoriesPageData? _data;
    private DetailMode _mode = DetailMode.None;
    private int? _selectedId;
    private bool _selectedIsActive;
    private string _filterText = "";
    private string _sortColumn = "Name";
    private bool _sortAscending = true;

    private string _formName = "";
    private string _formFundingStrategy = FundingStrategies.None;
    private Direction _formDirection = Direction.Expense;
    private decimal _formAmount;
    private Frequency _formFrequency = Frequency.Monthly;
    private DateOnly _formAnchor = DateOnly.FromDateTime(DateTime.Today);
    private int? _formAccountId;

    private AccountType? _formLinkedAccountType;
    private decimal? _formMinPayment;
    private decimal? _formExtraPayment;
    private int? _formPaymentDueDay;
    private int? _formStatementCloseDay;

    protected override async Task OnInitializedAsync()
    {
        _data = await CategoriesProvider.GetCategoriesAsync();
    }

    private static decimal? ParseNullableDecimal(string value) =>
        string.IsNullOrWhiteSpace(value) ? null : decimal.Parse(value);

    private static int? ParseNullableInt(string value) =>
        string.IsNullOrWhiteSpace(value) ? null : int.Parse(value);

    private static string FundingStrategyLabel(string strategy) => strategy switch
    {
        FundingStrategies.PayInFullAmex => "Pay in full (Amex)",
        FundingStrategies.Direct => "Direct",
        FundingStrategies.AccountPayment => "Account payment",
        _ => "None"
    };

    private static (string? Direction, string? Amount, string? Frequency) BudgetColumns(CategoryRow category)
    {
        if (category.FundingStrategy == FundingStrategies.AccountPayment)
        {
            // MinPayment/ExtraPayment - whatever this account alone contributes. Never
            // includes qualifying-spend categories' budgets (e.g. Groceries for Amex) -
            // those already have their own rows on this same list, so folding them in
            // here would double-count if this column is ever summed.
            var amount = (category.LinkedAccountMinPayment ?? 0m) + (category.LinkedAccountExtraPayment ?? 0m);

            return category.LinkedAccountId is null || amount == 0m
                ? (null, null, null)
                : ("Expense", amount.ToString("N2"), "Monthly");
        }

        return (category.BudgetDirection?.ToString(), category.BudgetAmount?.ToString("N2"), category.BudgetFrequency?.ToString());
    }

    private List<CategoryRow> VisibleCategories()
    {
        var filtered = _data!.Categories
            .Where(c => string.IsNullOrWhiteSpace(_filterText) || c.Name.Contains(_filterText, StringComparison.OrdinalIgnoreCase));

        Func<CategoryRow, object> keySelector = _sortColumn switch
        {
            "Funding" => c => c.FundingStrategy,
            "Status" => c => c.IsActive,
            _ => c => c.Name
        };

        var sorted = _sortAscending ? filtered.OrderBy(keySelector) : filtered.OrderByDescending(keySelector);
        return sorted.ToList();
    }

    private void Sort(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private void StartCreating()
    {
        _mode = DetailMode.Creating;
        _selectedId = null;
        _formName = "";
        _formFundingStrategy = FundingStrategies.None;
        _formDirection = Direction.Expense;
        _formAmount = 0m;
        _formFrequency = Frequency.Monthly;
        _formAnchor = DateOnly.FromDateTime(DateTime.Today);
        _formAccountId = null;
        _formLinkedAccountType = null;
        _formMinPayment = null;
        _formExtraPayment = null;
        _formPaymentDueDay = null;
        _formStatementCloseDay = null;
    }

    private Task SelectAsync(CategoryRow category)
    {
        _mode = DetailMode.Editing;
        _selectedId = category.Id;
        _selectedIsActive = category.IsActive;
        _formName = category.Name;
        _formFundingStrategy = category.FundingStrategy;
        _formDirection = category.BudgetDirection ?? Direction.Expense;
        _formAmount = category.BudgetAmount ?? 0m;
        _formFrequency = category.BudgetFrequency ?? Frequency.Monthly;
        _formAnchor = category.BudgetAnchor ?? DateOnly.FromDateTime(DateTime.Today);
        _formAccountId = category.BudgetAccountId;
        _formLinkedAccountType = category.LinkedAccountType;
        _formMinPayment = category.LinkedAccountMinPayment;
        _formExtraPayment = category.LinkedAccountExtraPayment;
        _formPaymentDueDay = category.LinkedAccountPaymentDueDay;
        _formStatementCloseDay = category.LinkedAccountStatementCloseDay;
        return Task.CompletedTask;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName)) return;

        BudgetInput? budget = _formFundingStrategy switch
        {
            FundingStrategies.Direct when _formAccountId is { } accountId =>
                new BudgetInput(_formAmount, _formFrequency, _formDirection, _formAnchor, accountId),
            FundingStrategies.PayInFullAmex =>
                new BudgetInput(_formAmount, _formFrequency),
            _ => null
        };

        AccountPaymentInput? accountPayment = _formFundingStrategy == FundingStrategies.AccountPayment && _formLinkedAccountType is not null
            ? new AccountPaymentInput(_formMinPayment, _formExtraPayment, _formPaymentDueDay, _formStatementCloseDay)
            : null;

        if (_mode == DetailMode.Creating)
        {
            await CategoriesProvider.CreateCategoryAsync(_formName, _formFundingStrategy, budget, accountPayment);
        }
        else if (_selectedId is { } id)
        {
            await CategoriesProvider.UpdateCategoryAsync(id, _formName, _formFundingStrategy, budget, accountPayment);
        }

        _mode = DetailMode.None;
        _selectedId = null;
        _data = await CategoriesProvider.GetCategoriesAsync();
    }

    private async Task DeactivateAsync()
    {
        if (_selectedId is not { } id) return;
        await CategoriesProvider.DeactivateCategoryAsync(id);
        _mode = DetailMode.None;
        _selectedId = null;
        _data = await CategoriesProvider.GetCategoriesAsync();
    }

    private async Task ReactivateAsync()
    {
        if (_selectedId is not { } id) return;
        await CategoriesProvider.ReactivateCategoryAsync(id);
        _mode = DetailMode.None;
        _selectedId = null;
        _data = await CategoriesProvider.GetCategoriesAsync();
    }
}
