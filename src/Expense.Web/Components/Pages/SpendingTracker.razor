@page "/spending-tracker"
@using Expense.Domain.Services.SpendingTracker
@inject ISpendingTrackerPageProvider SpendingTrackerProvider

<PageTitle>Spending Tracker</PageTitle>

<h1>Spending Tracker</h1>

@if (_data is null)
{
    <p>Loading...</p>
}
else
{
    <div style="display:flex; gap:3rem; align-items:flex-start;">
        @RenderPeriod("This Week", "week", _data.Week)
        @RenderPeriod("This Month", "month", _data.Month)
    </div>
}

@code {
    private SpendingTrackerPageData? _data;

    protected override async Task OnInitializedAsync()
    {
        _data = await SpendingTrackerProvider.GetSpendingTrackerAsync();
    }

    private RenderFragment RenderPeriod(string title, string idPrefix, SpendingTrackerResult result) => @<div>
        <h2>@title</h2>
        <p>@result.PeriodStart.ToString("yyyy-MM-dd") to @result.PeriodEnd.ToString("yyyy-MM-dd")</p>
        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th class="text-right">Budget</th>
                    <th class="text-right">Actual</th>
                    <th class="text-right">Remaining</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in result.Categories)
                {
                    <tr>
                        <td>@category.CategoryName</td>
                        <td class="text-right">@category.Budget.ToString("N2")</td>
                        <td class="text-right">@category.Actual.ToString("N2")</td>
                        <td class="text-right">@category.Remaining.ToString("N2")</td>
                    </tr>
                }
                <tr>
                    <td>Pending / Uncategorized</td>
                    <td></td>
                    <td class="text-right">@result.PendingAmount.ToString("N2")</td>
                    <td></td>
                </tr>
            </tbody>
            <tfoot>
                @{
                    var budgetTotal = result.Categories.Sum(c => c.Budget);
                    // Pending is real money already spent, just not yet sorted into a
                    // category - it has to count toward the actual/remaining totals or
                    // this row would overstate how much budget is really left, the exact
                    // kind of "silently ignore uncategorized spend" mistake already fixed
                    // once before for the Amex forecast.
                    var actualTotal = result.Categories.Sum(c => c.Actual) + result.PendingAmount;
                }
                <tr id="@(idPrefix)-totals-row" style="font-weight: 600; border-top: 2px solid var(--color-border, #ccc)">
                    <td>Total</td>
                    <td class="text-right">@budgetTotal.ToString("N2")</td>
                    <td class="text-right">@actualTotal.ToString("N2")</td>
                    <td class="text-right">@((budgetTotal - actualTotal).ToString("N2"))</td>
                </tr>
            </tfoot>
        </table>
    </div>;
}
