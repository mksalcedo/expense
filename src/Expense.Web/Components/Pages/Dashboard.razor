@page "/"
@using Expense.Domain.Entities
@using Expense.Domain.Services.Categorization
@using Expense.Domain.Services.Dashboard
@using Expense.Domain.Services.Forecast
@using Expense.Domain.Services.SpendingTracker
@inject IForecastResultProvider ForecastProvider
@inject ISpendingTrackerPageProvider SpendingTrackerProvider
@inject IReviewQueueProvider ReviewQueueProvider
@inject ISyncStatusProvider SyncStatusProvider

<PageTitle>Dashboard</PageTitle>

<h1>Dashboard</h1>

@if (_forecast is null || _spendingTracker is null || _reviewQueue is null)
{
    <p>Loading...</p>
}
else
{
    <div style="display:flex; gap:3rem; align-items:flex-start; flex-wrap:wrap;">
        <div>
            <h2>Cash Flow</h2>
            <p>Starting balance: @_forecast.StartingBalance.ToString("N2")</p>
            <p>
                Lowest projected balance: @_forecast.LowestProjectedBalance.ToString("N2")
                @if (_forecast.LowestProjectedBalanceDate is { } lowestDate)
                {
                    <text> (Occurs on @lowestDate.ToString("MM/dd/yyyy"))</text>
                }
            </p>
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th class="text-right">Amount</th>
                        <th class="text-right">Running balance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _forecast.Rows.Take(20))
                    {
                        <tr>
                            <td>@row.Date.ToString("yyyy-MM-dd")</td>
                            <td>@row.Description</td>
                            <td class="text-right">@row.Amount.ToString("N2")</td>
                            <td class="text-right">@row.RunningBalance.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
            <p><a href="/forecast">View full forecast</a></p>
        </div>

        <div>
            @RenderSpendingTable("This Week's Spending", "spending-week", _spendingTracker.Week)
            @RenderSpendingTable("This Month's Spending", "spending-month", _spendingTracker.Month)
            <p><a href="/spending-tracker">View spending tracker</a></p>
        </div>

        <div>
            <h2>Review Queue</h2>
            <p>@PendingGroupCount item(s) need categorization</p>
            <p><a href="/review-queue">Go to Review Queue</a></p>
        </div>

        <div>
            <h2>Sync Now</h2>
            <div>
                <button id="sync-simplefin-btn" @onclick="RunSimpleFinSyncAsync" disabled="@_simpleFinRunning">
                    @(_simpleFinRunning ? "Syncing..." : "Sync Bank Accounts (SimpleFin)")
                </button>
                <p id="sync-simplefin-status">@FormatRunStatus(_lastSimpleFinRun)</p>
                @if (_lastSimpleFinRun?.Summary is { } simpleFinSummary)
                {
                    <p id="sync-simplefin-summary">@simpleFinSummary</p>
                }
            </div>
            <div>
                <button id="sync-amazon-btn" @onclick="RunAmazonGmailSyncAsync" disabled="@_amazonRunning">
                    @(_amazonRunning ? "Syncing..." : "Sync Amazon Orders (via Gmail)")
                </button>
                <p><em>Scans Gmail for Amazon order/refund emails - this is how Amazon purchases get into Expense.</em></p>
                <p id="sync-amazon-status">@FormatRunStatus(_lastAmazonRun)</p>
                @if (_lastAmazonRun?.Summary is { } amazonSummary)
                {
                    <p id="sync-amazon-summary">@amazonSummary</p>
                }
            </div>

            @if (_syncIssues.Count > 0)
            {
                <div id="sync-issues-section">
                    <h3>Sync issues need review (@_syncIssues.Count)</h3>
                    @foreach (var issue in _syncIssues)
                    {
                        var form = GetResolveForm(issue.Id);
                        <div id="sync-issue-@issue.Id" style="border: 1px solid var(--color-border, #ccc); padding: 10px; margin-bottom: 10px;">
                            <p><strong>@issue.Subject</strong> &mdash; @issue.Reason</p>
                            <p>Received: @issue.ReceivedDate.ToString("MM/dd/yyyy")</p>
                            @if (issue.Body is { } body)
                            {
                                <pre style="max-height: 150px; overflow-y: auto; background: var(--color-surface, #f5f5f5); padding: 6px;">@body</pre>
                            }
                            <div>
                                <input id="resolve-order-id-@issue.Id" placeholder="Order ID" @onchange="e => form.OrderId = (string)e.Value!" />
                                <input id="resolve-item-title-@issue.Id" placeholder="Item title" @onchange="e => form.ItemTitle = (string)e.Value!" />
                                <input id="resolve-price-@issue.Id" type="number" step="0.01" placeholder="Price" @onchange="e => form.Price = (string)e.Value!" />
                                <input id="resolve-quantity-@issue.Id" type="number" value="@form.Quantity" @onchange="e => form.Quantity = int.Parse((string)e.Value!)" />
                                <button id="resolve-btn-@issue.Id" @onclick="() => ResolveSyncIssueAsync(issue.Id)">Resolve</button>
                                <button id="ignore-not-order-btn-@issue.Id" @onclick="() => IgnoreSyncIssueAsync(issue.Id)">Not a real order</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private ForecastResult? _forecast;
    private SpendingTrackerPageData? _spendingTracker;
    private ReviewQueueData? _reviewQueue;
    private ImportRun? _lastSimpleFinRun;
    private ImportRun? _lastAmazonRun;
    private bool _simpleFinRunning;
    private bool _amazonRunning;
    private List<SyncIssue> _syncIssues = [];

    private int PendingGroupCount => (_reviewQueue?.TransactionGroups.Count ?? 0) + (_reviewQueue?.AmazonItemGroups.Count ?? 0);

    protected override async Task OnInitializedAsync()
    {
        await RefreshDashboardDataAsync();
        _lastSimpleFinRun = await SyncStatusProvider.GetLastSimpleFinRunAsync();
        _lastAmazonRun = await SyncStatusProvider.GetLastAmazonGmailRunAsync();
        _syncIssues = await SyncStatusProvider.GetActiveSyncIssuesAsync();
    }

    private async Task RunSimpleFinSyncAsync()
    {
        _simpleFinRunning = true;
        try
        {
            _lastSimpleFinRun = await SyncStatusProvider.RunSimpleFinSyncAsync();
            await RefreshDashboardDataAsync();
        }
        finally
        {
            _simpleFinRunning = false;
        }
    }

    private async Task RunAmazonGmailSyncAsync()
    {
        _amazonRunning = true;
        try
        {
            _lastAmazonRun = await SyncStatusProvider.RunAmazonGmailSyncAsync();
            await RefreshDashboardDataAsync();
            _syncIssues = await SyncStatusProvider.GetActiveSyncIssuesAsync();
        }
        finally
        {
            _amazonRunning = false;
        }
    }

    private class ResolveFormState
    {
        public string OrderId { get; set; } = "";
        public string ItemTitle { get; set; } = "";
        public string Price { get; set; } = "";
        public int Quantity { get; set; } = 1;
    }

    private readonly Dictionary<int, ResolveFormState> _resolveForms = [];

    private ResolveFormState GetResolveForm(int issueId) =>
        _resolveForms.TryGetValue(issueId, out var form) ? form : _resolveForms[issueId] = new ResolveFormState();

    private async Task ResolveSyncIssueAsync(int syncIssueId)
    {
        var form = GetResolveForm(syncIssueId);
        if (string.IsNullOrWhiteSpace(form.OrderId) || string.IsNullOrWhiteSpace(form.ItemTitle) || !decimal.TryParse(form.Price, out var price))
        {
            return;
        }

        await SyncStatusProvider.ResolveSyncIssueAsync(syncIssueId, form.OrderId, form.ItemTitle, price, form.Quantity);
        _resolveForms.Remove(syncIssueId);
        _syncIssues = await SyncStatusProvider.GetActiveSyncIssuesAsync();
    }

    private async Task IgnoreSyncIssueAsync(int syncIssueId)
    {
        await SyncStatusProvider.IgnoreSyncIssueAsync(syncIssueId);
        _resolveForms.Remove(syncIssueId);
        _syncIssues = await SyncStatusProvider.GetActiveSyncIssuesAsync();
    }

    // A sync can add transactions/orders that change every figure shown on this page -
    // the running balance, category totals, and how many rows still need categorization -
    // so all three get reloaded once the import itself finishes, not just the "Last
    // synced" timestamp.
    private async Task RefreshDashboardDataAsync()
    {
        _forecast = await ForecastProvider.GetForecastAsync();
        _spendingTracker = await SpendingTrackerProvider.GetSpendingTrackerAsync();
        _reviewQueue = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private static string FormatRunStatus(ImportRun? run)
    {
        if (run is null) return "Last synced: never";
        var when = run.RanAt.ToLocalTime().ToString("MM/dd/yyyy h:mm tt");
        return run.Success ? $"Last synced: {when}" : $"Last synced: {when} - FAILED: {run.ErrorMessage}";
    }

    // Same table shape (category rows + Pending row + Totals row folding Pending into
    // Actual/Remaining) as the Spending Tracker page itself - kept in sync deliberately,
    // since this is meant to be a faithful at-a-glance copy, not a simplified one.
    private static RenderFragment RenderSpendingTable(string title, string idPrefix, SpendingTrackerResult result) => @<div style="margin-bottom: 3.5em;">
        <h2>@title</h2>
        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th class="text-right">Budget</th>
                    <th class="text-right">Actual</th>
                    <th class="text-right">Remaining</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in result.Categories)
                {
                    <tr>
                        <td>@category.CategoryName</td>
                        <td class="text-right">@category.Budget.ToString("N2")</td>
                        <td class="text-right">@category.Actual.ToString("N2")</td>
                        <td class="text-right">@category.Remaining.ToString("N2")</td>
                    </tr>
                }
                <tr id="@(idPrefix)-pending-row">
                    <td>Pending / Uncategorized</td>
                    <td></td>
                    <td class="text-right">@result.PendingAmount.ToString("N2")</td>
                    <td></td>
                </tr>
            </tbody>
            <tfoot>
                @{
                    var budgetTotal = result.Categories.Sum(c => c.Budget);
                    var actualTotal = result.Categories.Sum(c => c.Actual) + result.PendingAmount;
                }
                <tr id="@(idPrefix)-totals-row" style="font-weight: 600; border-top: 2px solid var(--color-border, #ccc)">
                    <td>Total</td>
                    <td class="text-right">@budgetTotal.ToString("N2")</td>
                    <td class="text-right">@actualTotal.ToString("N2")</td>
                    <td class="text-right">@((budgetTotal - actualTotal).ToString("N2"))</td>
                </tr>
            </tfoot>
        </table>
    </div>;
}
