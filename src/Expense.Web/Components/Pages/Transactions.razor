@page "/transactions"
@using Expense.Domain.Services.Transactions
@using Microsoft.AspNetCore.Components
@inject ITransactionsPageProvider TransactionsProvider
@inject IJSRuntime JS

<PageTitle>Transactions</PageTitle>

<h1>Transactions</h1>

@if (!string.IsNullOrEmpty(SearchQuery))
{
    <p><a id="back-to-review-queue-link" href="/review-queue">&larr; Back to Review Queue</a></p>
}

<p>
    <input id="search-box" placeholder="Search description..." value="@_searchText" @onchange="e => SearchAsync((string?)e.Value)" />
    <select id="category-filter" @onchange="e => FilterByCategoryAsync((string)e.Value!)">
        <option value="-1">-- all categories --</option>
        <option value="0">-- uncategorized --</option>
        @if (_data is not null)
        {
            @foreach (var category in _data.Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        }
    </select>
    <label>
        <input type="checkbox" id="needs-review-filter" checked="@_needsReviewOnly" @onchange="e => FilterByNeedsReviewAsync((bool)e.Value!)" />
        Needs Review only
    </label>
</p>

@if (_data is null)
{
    <p>Loading...</p>
}
else
{
    <p>
        <span id="selected-count">@(_selectedBankIds.Count + _selectedAmazonIds.Count) selected</span>
        <select id="bulk-category" @bind="_selectedBulkCategoryId">
            <option value="0">-- choose category --</option>
            @foreach (var category in _data.Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
        <button id="apply-bulk-category-btn" disabled="@(_selectedBulkCategoryId == 0 || (_selectedBankIds.Count == 0 && _selectedAmazonIds.Count == 0))"
                @onclick="ApplyBulkCategoryAsync">
            Apply
        </button>
    </p>

    <p>
        <button id="prev-page-btn" disabled="@(_currentPage <= 1)" @onclick="() => GoToPageAsync(_currentPage - 1)">&laquo; Previous</button>
        <span id="page-indicator">Page @_currentPage of @TotalPages</span>
        <button id="next-page-btn" disabled="@(_currentPage >= TotalPages)" @onclick="() => GoToPageAsync(_currentPage + 1)">Next &raquo;</button>
        <span>(@_data.TotalCount total)</span>
        <label>
            Rows per page:
            <select id="page-size-select" value="@_pageSize" @onchange="e => ChangePageSizeAsync(int.Parse((string)e.Value!))">
                @foreach (var size in PageSizeOptions)
                {
                    <option value="@size">@size</option>
                }
            </select>
        </label>
    </p>

    <table>
        <thead>
            <tr>
                <th></th>
                <th>Date</th>
                <th>Description</th>
                <th>Order ID</th>
                <th>Amount</th>
                <th>Source</th>
                <th>Category</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (row, index) in _data.Transactions.Select((r, i) => (r, i)))
            {
                <tr @key="(row.Source, row.Id)" style="@(row.NeedsReview ? "background-color: yellow" : null)">
                    <td>
                        @if (row.Source == TransactionSource.Bank)
                        {
                            <input type="checkbox" id="select-bank-@row.Id" checked="@_selectedBankIds.Contains(row.Id)"
                                   @onclick="e => ToggleSelection(index, e.ShiftKey)" />
                        }
                        else
                        {
                            <input type="checkbox" id="select-amazon-@row.Id" checked="@_selectedAmazonIds.Contains(row.Id)"
                                   @onclick="e => ToggleSelection(index, e.ShiftKey)" />
                        }
                    </td>
                    <td>@row.Date.ToString("MM/dd/yyyy")</td>
                    <td>
                        @if (row.Source == TransactionSource.Amazon)
                        {
                            <input id="amazon-title-@row.Id" value="@row.Description"
                                   @onchange="e => UpdateAmazonItemDetailsAsync(row, title: (string?)e.Value, price: null, quantity: null)" />
                        }
                        else
                        {
                            @row.Description
                        }
                    </td>
                    <td>@row.OrderId</td>
                    <td>
                        @if (row.Source == TransactionSource.Amazon)
                        {
                            <input id="amazon-price-@row.Id" type="number" step="0.01" value="@row.Price"
                                   @onchange="e => UpdateAmazonItemDetailsAsync(row, title: null, price: (string?)e.Value, quantity: null)" />
                            <text> x </text>
                            <input id="amazon-quantity-@row.Id" type="number" value="@row.Quantity"
                                   @onchange="e => UpdateAmazonItemDetailsAsync(row, title: null, price: null, quantity: (string?)e.Value)" />
                        }
                        else
                        {
                            @row.Amount.ToString("N2")
                        }
                    </td>
                    <td>@(row.Source == TransactionSource.Bank ? "Bank" : "Amazon")</td>
                    <td>
                        <select id="category-@(row.Source == TransactionSource.Bank ? "bank" : "amazon")-@row.Id"
                                @onchange="e => UpdateCategoryAsync(row, int.Parse((string)e.Value!))">
                            <option value="0" selected="@(row.CategoryId is null)">-- Uncategorized --</option>
                            @foreach (var category in _data.Categories)
                            {
                                <option value="@category.Id" selected="@(row.CategoryId == category.Id)">@category.Name</option>
                            }
                        </select>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <p>
        <button disabled="@(_currentPage <= 1)" @onclick="() => GoToPageAsync(_currentPage - 1)">&laquo; Previous</button>
        <span>Page @_currentPage of @TotalPages</span>
        <button disabled="@(_currentPage >= TotalPages)" @onclick="() => GoToPageAsync(_currentPage + 1)">Next &raquo;</button>
    </p>
}

@code {
    private const string PageSizeStorageKey = "expense-transactions-page-size";
    private static readonly int[] PageSizeOptions = [15, 20, 40, 60, 80, 100];

    private TransactionsPageData? _data;
    private string? _searchText;
    private int? _categoryFilter;
    private bool _needsReviewOnly;
    private int _pageSize = 20;
    private int _currentPage = 1;
    private readonly HashSet<int> _selectedBankIds = [];
    private readonly HashSet<int> _selectedAmazonIds = [];
    private int? _lastClickedIndex;
    private int _selectedBulkCategoryId;

    private int TotalPages => _data is null || _data.TotalCount == 0 ? 1 : (int)Math.Ceiling(_data.TotalCount / (double)_pageSize);

    /// <summary>Prefills the search box for deep links from the Review Queue's "View individual items" link.</summary>
    [Parameter]
    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchQuery { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _searchText = SearchQuery;
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", PageSizeStorageKey);
        if (int.TryParse(saved, out var savedSize) && PageSizeOptions.Contains(savedSize) && savedSize != _pageSize)
        {
            _pageSize = savedSize;
            await LoadDataAsync();
            StateHasChanged();
        }
    }

    private async Task LoadDataAsync()
    {
        _data = await TransactionsProvider.GetTransactionsAsync(_searchText, _categoryFilter, _needsReviewOnly, _currentPage, _pageSize);
    }

    private async Task GoToPageAsync(int page)
    {
        if (page < 1 || page > TotalPages) return;
        _currentPage = page;
        await LoadDataAsync();
    }

    private async Task ChangePageSizeAsync(int pageSize)
    {
        _pageSize = pageSize;
        _currentPage = 1;
        await JS.InvokeVoidAsync("localStorage.setItem", PageSizeStorageKey, pageSize.ToString());
        await LoadDataAsync();
    }

    private async Task SearchAsync(string? searchText)
    {
        _searchText = searchText;
        _currentPage = 1;
        await LoadDataAsync();
    }

    private async Task FilterByCategoryAsync(string value)
    {
        var parsed = int.Parse(value);
        _categoryFilter = parsed == -1 ? null : parsed;
        _currentPage = 1;
        await LoadDataAsync();
    }

    private async Task FilterByNeedsReviewAsync(bool needsReviewOnly)
    {
        _needsReviewOnly = needsReviewOnly;
        _currentPage = 1;
        await LoadDataAsync();
    }

    private async Task UpdateCategoryAsync(TransactionRow row, int value)
    {
        var categoryId = value == 0 ? (int?)null : value;
        await TransactionsProvider.UpdateCategoryAsync(row.Source, row.Id, categoryId);

        row.CategoryId = categoryId;
        row.CategoryName = categoryId is { } id ? _data!.Categories.First(c => c.Id == id).Name : null;
    }

    // Gmail-style multi-select, same as the Review Queue: a plain click toggles just that
    // row; shift-click selects every row between the last-clicked one and this one
    // (inclusive), by visual position - regardless of whether those rows are Bank or
    // Amazon, since they're sorted together in one combined, date-ordered list. This is
    // necessarily scoped to the current page only - rows on a different page aren't in the
    // DOM to select, same as any other paginated list.
    private void ToggleSelection(int index, bool shiftKey)
    {
        if (_data is null) return;

        if (shiftKey && _lastClickedIndex is { } lastIndex)
        {
            var (from, to) = lastIndex <= index ? (lastIndex, index) : (index, lastIndex);
            for (var i = from; i <= to; i++)
            {
                Select(_data.Transactions[i]);
            }
        }
        else
        {
            ToggleSingle(_data.Transactions[index]);
        }
        _lastClickedIndex = index;
    }

    private void Select(TransactionRow row)
    {
        (row.Source == TransactionSource.Bank ? _selectedBankIds : _selectedAmazonIds).Add(row.Id);
    }

    private void ToggleSingle(TransactionRow row)
    {
        var selection = row.Source == TransactionSource.Bank ? _selectedBankIds : _selectedAmazonIds;
        if (!selection.Add(row.Id))
        {
            selection.Remove(row.Id);
        }
    }

    private async Task ApplyBulkCategoryAsync()
    {
        if (_selectedBulkCategoryId == 0 || (_selectedBankIds.Count == 0 && _selectedAmazonIds.Count == 0)) return;

        await TransactionsProvider.BulkCategorizeAsync(_selectedBankIds.ToList(), _selectedAmazonIds.ToList(), _selectedBulkCategoryId);

        _selectedBankIds.Clear();
        _selectedAmazonIds.Clear();
        _lastClickedIndex = null;
        await LoadDataAsync();
    }

    private async Task UpdateAmazonItemDetailsAsync(TransactionRow row, string? title, string? price, string? quantity)
    {
        var newTitle = title ?? row.Description;
        var newPrice = price is not null ? decimal.Parse(price) : row.Price!.Value;
        var newQuantity = quantity is not null ? int.Parse(quantity) : row.Quantity!.Value;

        await TransactionsProvider.UpdateAmazonItemDetailsAsync(row.Id, newTitle, newPrice, newQuantity);

        row.Description = newTitle;
        row.Price = newPrice;
        row.Quantity = newQuantity;
    }
}
