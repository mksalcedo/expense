@page "/review-queue"
@using Expense.Domain.Services.Categorization
@inject IReviewQueueProvider ReviewQueueProvider

<PageTitle>Review Queue</PageTitle>

<h1>Review Queue</h1>

<p>
    <button id="reapply-rules-btn" @onclick="ReapplyRulesAsync" disabled="@_reapplyingRules">
        @(_reapplyingRules ? "Re-applying..." : "Re-apply Rules Now")
    </button>
    @if (_reapplyMessage is not null)
    {
        <span> @_reapplyMessage</span>
    }
</p>

@if (_data is null)
{
    <p>Loading...</p>
}
else
{
    <h2>Bank Transactions (@_data.TransactionGroups.Count groups, @_data.TransactionGroups.Sum(g => g.TransactionIds.Count) transactions)</h2>
    <p>
        <span id="txn-selected-count">@_selectedTransactionIndexes.Count selected</span>
        <select id="txn-bulk-category" @bind="_selectedBulkTransactionCategoryId">
            <option value="0">-- choose category --</option>
            @foreach (var category in _data.Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
        <button id="txn-apply-bulk-category-btn" disabled="@(_selectedTransactionIndexes.Count == 0 || _selectedBulkTransactionCategoryId == 0)"
                @onclick="BulkCategorizeTransactionsAsync">
            Apply
        </button>
        <button id="txn-dismiss-btn" disabled="@(_selectedTransactionIndexes.Count == 0)" @onclick="DismissTransactionsAsync">
            Dismiss (review later)
        </button>
    </p>
    <table>
        <thead>
            <tr>
                <th>
                    <input type="checkbox" id="txn-select-all"
                           checked="@(_data.TransactionGroups.Count > 0 && _selectedTransactionIndexes.Count == _data.TransactionGroups.Count)"
                           @onclick="ToggleSelectAllTransactions" />
                </th>
                <th>Count</th>
                <th>Sample description</th>
                <th>Account</th>
                <th>Date</th>
                <th>Total</th>
                <th>Pattern (edit if needed)</th>
                <th>Category</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @* @key is required here: without it, categorizing one group removes it from the
               list, and the remaining rows shift up - Blazor then reuses the removed row's
               DOM <select> (with whatever category the user had just picked still "selected"
               in the live browser) for whichever group now occupies that position, making it
               look like that group's category silently changed. Keying by representativeId
               makes Blazor track each row by its real identity instead of its position. *@
            @foreach (var (group, index) in _data.TransactionGroups.Select((g, i) => (g, i)))
            {
                var representativeId = group.TransactionIds[0];
                <tr @key="representativeId">
                    <td>
                        <input type="checkbox" id="txn-select-@representativeId" checked="@_selectedTransactionIndexes.Contains(index)"
                               @onclick="e => ToggleTransactionSelection(index, e.ShiftKey)" />
                    </td>
                    <td>@group.TransactionIds.Count</td>
                    <td>@group.SampleDescription</td>
                    <td>@group.AccountName</td>
                    <td>@group.SampleDate.ToString("MM/dd/yyyy")</td>
                    <td>@group.TotalAmount.ToString("N2")</td>
                    <td>
                        <input id="txn-pattern-@representativeId" value="@group.SuggestedPattern"
                               @onchange="e => _transactionPattern[representativeId] = (string?)e.Value" />
                    </td>
                    <td>
                        <select id="txn-category-@representativeId"
                                @onchange="e => CategorizeTransactionGroupAsync(group, int.Parse((string)e.Value!))">
                            <option value="0">-- select --</option>
                            @foreach (var category in _data.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                    </td>
                    <td>
                        <a id="txn-view-individual-@representativeId" href="@($"/transactions?search={Uri.EscapeDataString(group.SuggestedPattern)}")">
                            View individual items
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h2>Amazon Items (@_data.AmazonItemGroups.Count groups, @_data.AmazonItemGroups.Sum(g => g.ItemIds.Count) items)</h2>
    <p>
        <span id="item-selected-count">@_selectedItemIndexes.Count selected</span>
        <select id="item-bulk-category" @bind="_selectedBulkItemCategoryId">
            <option value="0">-- choose category --</option>
            @foreach (var category in _data.Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
        <button id="item-apply-bulk-category-btn" disabled="@(_selectedItemIndexes.Count == 0 || _selectedBulkItemCategoryId == 0)"
                @onclick="BulkCategorizeAmazonItemsAsync">
            Apply
        </button>
        <button id="item-dismiss-btn" disabled="@(_selectedItemIndexes.Count == 0)" @onclick="DismissAmazonItemsAsync">
            Dismiss (review later)
        </button>
    </p>
    <table>
        <thead>
            <tr>
                <th>
                    <input type="checkbox" id="item-select-all"
                           checked="@(_data.AmazonItemGroups.Count > 0 && _selectedItemIndexes.Count == _data.AmazonItemGroups.Count)"
                           @onclick="ToggleSelectAllItems" />
                </th>
                <th>Count</th>
                <th>Item</th>
                <th>Order ID</th>
                <th>Date</th>
                <th>Total</th>
                <th>Pattern (edit if needed)</th>
                <th>Category</th>
            </tr>
        </thead>
        <tbody>
            @* Same @key reasoning as the transactions table above. *@
            @foreach (var (group, index) in _data.AmazonItemGroups.Select((g, i) => (g, i)))
            {
                var representativeId = group.ItemIds[0];
                <tr @key="representativeId" style="@(group.NeedsReview ? "background-color: yellow" : null)">
                    <td>
                        <input type="checkbox" id="item-select-@representativeId" checked="@_selectedItemIndexes.Contains(index)"
                               @onclick="e => ToggleItemSelection(index, e.ShiftKey)" />
                    </td>
                    <td>@group.ItemIds.Count</td>
                    <td>@group.ItemTitle</td>
                    <td>@group.OrderId</td>
                    <td>@group.SampleDate.ToString("MM/dd/yyyy")</td>
                    <td>@group.TotalPrice.ToString("N2")</td>
                    <td>
                        <input id="item-pattern-@representativeId" value="@group.SuggestedPattern"
                               @onchange="e => _itemPattern[representativeId] = (string?)e.Value" />
                    </td>
                    <td>
                        <select id="item-category-@representativeId"
                                @onchange="e => CategorizeAmazonItemGroupAsync(group, int.Parse((string)e.Value!))">
                            <option value="0">-- select --</option>
                            @foreach (var category in _data.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_confirmSingleWordModalOpen)
{
    <div id="confirm-single-word-modal" style="position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div style="background: var(--color-surface, white); width: 90%; max-width: 500px; padding: 20px; border-radius: 6px;">
            <h2 style="margin-top: 0;">Use this single-word pattern?</h2>
            <p>
                "@_confirmSingleWordPattern" is a single word. That's fine for a truly distinctive name (e.g. a specific
                brand), but a generic term like "payment" or "fee" would match unrelated transactions too. Make sure
                this is specific to one merchant before continuing.
            </p>
            <p>
                <button id="confirm-single-word-btn" @onclick="ConfirmSingleWordPatternAsync">Use It Anyway</button>
                <button id="cancel-single-word-btn" @onclick="CancelSingleWordPattern">Cancel</button>
            </p>
        </div>
    </div>
}

@code {
    private ReviewQueueData? _data;
    private readonly Dictionary<int, string?> _transactionPattern = [];
    private readonly Dictionary<int, string?> _itemPattern = [];
    private bool _reapplyingRules;
    private string? _reapplyMessage;

    private readonly HashSet<int> _selectedTransactionIndexes = [];
    private int? _lastClickedTransactionIndex;
    private int _selectedBulkTransactionCategoryId;
    private readonly HashSet<int> _selectedItemIndexes = [];
    private int? _lastClickedItemIndex;
    private int _selectedBulkItemCategoryId;

    private bool _confirmSingleWordModalOpen;
    private string? _confirmSingleWordPattern;
    private Func<Task>? _pendingSingleWordAction;

    protected override async Task OnInitializedAsync()
    {
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private async Task ReapplyRulesAsync()
    {
        _reapplyingRules = true;
        _reapplyMessage = null;
        try
        {
            var result = await ReviewQueueProvider.ReapplyRulesAsync();
            var total = result.TransactionsUpdated + result.ItemsUpdated;
            _reapplyMessage = total > 0
                ? $"Re-categorized {total} previously pending row(s)."
                : "Nothing else matched the current rules.";
            _data = await ReviewQueueProvider.GetReviewQueueAsync();
        }
        finally
        {
            _reapplyingRules = false;
        }
    }

    private async Task CategorizeTransactionGroupAsync(PendingTransactionGroup group, int categoryId)
    {
        if (categoryId == 0) return;

        var representativeId = group.TransactionIds[0];
        var pattern = _transactionPattern.TryGetValue(representativeId, out var edited) ? edited : group.SuggestedPattern;
        var patternToCreate = string.IsNullOrWhiteSpace(pattern) ? null : pattern;

        if (patternToCreate is not null && MerchantPatternMatcher.IsSingleWord(patternToCreate))
        {
            _confirmSingleWordPattern = patternToCreate;
            _pendingSingleWordAction = () => CommitTransactionCategorizationAsync(representativeId, categoryId, patternToCreate);
            _confirmSingleWordModalOpen = true;
            return;
        }

        await CommitTransactionCategorizationAsync(representativeId, categoryId, patternToCreate);
    }

    private async Task CommitTransactionCategorizationAsync(int representativeId, int categoryId, string? pattern)
    {
        await ReviewQueueProvider.CategorizeTransactionAsync(representativeId, categoryId, pattern);
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private async Task CategorizeAmazonItemGroupAsync(PendingAmazonItemGroup group, int categoryId)
    {
        if (categoryId == 0) return;

        var representativeId = group.ItemIds[0];
        var pattern = _itemPattern.TryGetValue(representativeId, out var edited) ? edited : group.SuggestedPattern;
        var patternToCreate = string.IsNullOrWhiteSpace(pattern) ? null : pattern;

        if (patternToCreate is not null && MerchantPatternMatcher.IsSingleWord(patternToCreate))
        {
            _confirmSingleWordPattern = patternToCreate;
            _pendingSingleWordAction = () => CommitAmazonItemCategorizationAsync(representativeId, categoryId, patternToCreate);
            _confirmSingleWordModalOpen = true;
            return;
        }

        await CommitAmazonItemCategorizationAsync(representativeId, categoryId, patternToCreate);
    }

    private async Task CommitAmazonItemCategorizationAsync(int representativeId, int categoryId, string? pattern)
    {
        await ReviewQueueProvider.CategorizeAmazonItemAsync(representativeId, categoryId, pattern);
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private async Task ConfirmSingleWordPatternAsync()
    {
        _confirmSingleWordModalOpen = false;
        _confirmSingleWordPattern = null;
        if (_pendingSingleWordAction is { } action)
        {
            _pendingSingleWordAction = null;
            await action();
        }
    }

    private void CancelSingleWordPattern()
    {
        _confirmSingleWordModalOpen = false;
        _confirmSingleWordPattern = null;
        _pendingSingleWordAction = null;
    }

    // Gmail-style multi-select: a plain click toggles just that row; shift-click selects
    // every row between the last-clicked one and this one (inclusive), by visual position.
    private void ToggleTransactionSelection(int index, bool shiftKey)
    {
        if (shiftKey && _lastClickedTransactionIndex is { } lastIndex)
        {
            var (from, to) = lastIndex <= index ? (lastIndex, index) : (index, lastIndex);
            for (var i = from; i <= to; i++) _selectedTransactionIndexes.Add(i);
        }
        else if (!_selectedTransactionIndexes.Add(index))
        {
            _selectedTransactionIndexes.Remove(index);
        }
        _lastClickedTransactionIndex = index;
    }

    private void ToggleSelectAllTransactions()
    {
        if (_data is null) return;
        if (_selectedTransactionIndexes.Count == _data.TransactionGroups.Count)
        {
            _selectedTransactionIndexes.Clear();
        }
        else
        {
            _selectedTransactionIndexes.Clear();
            for (var i = 0; i < _data.TransactionGroups.Count; i++) _selectedTransactionIndexes.Add(i);
        }
    }

    private async Task BulkCategorizeTransactionsAsync()
    {
        if (_selectedBulkTransactionCategoryId == 0 || _data is null || _selectedTransactionIndexes.Count == 0) return;

        var transactionIds = _selectedTransactionIndexes.SelectMany(i => _data.TransactionGroups[i].TransactionIds).ToList();
        await ReviewQueueProvider.BulkCategorizeTransactionsAsync(transactionIds, _selectedBulkTransactionCategoryId);

        // Clear the row selection, but deliberately leave the category dropdown as-is:
        // applying the same category to a second, different batch of rows is a common
        // real workflow, and a plain <select> only fires a change event when its value
        // actually changes - keeping the value lets the Apply button alone drive repeats.
        _selectedTransactionIndexes.Clear();
        _lastClickedTransactionIndex = null;
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private async Task DismissTransactionsAsync()
    {
        if (_data is null || _selectedTransactionIndexes.Count == 0) return;

        var transactionIds = _selectedTransactionIndexes.SelectMany(i => _data.TransactionGroups[i].TransactionIds).ToList();
        await ReviewQueueProvider.DismissTransactionsAsync(transactionIds);

        _selectedTransactionIndexes.Clear();
        _lastClickedTransactionIndex = null;
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private void ToggleItemSelection(int index, bool shiftKey)
    {
        if (shiftKey && _lastClickedItemIndex is { } lastIndex)
        {
            var (from, to) = lastIndex <= index ? (lastIndex, index) : (index, lastIndex);
            for (var i = from; i <= to; i++) _selectedItemIndexes.Add(i);
        }
        else if (!_selectedItemIndexes.Add(index))
        {
            _selectedItemIndexes.Remove(index);
        }
        _lastClickedItemIndex = index;
    }

    private void ToggleSelectAllItems()
    {
        if (_data is null) return;
        if (_selectedItemIndexes.Count == _data.AmazonItemGroups.Count)
        {
            _selectedItemIndexes.Clear();
        }
        else
        {
            _selectedItemIndexes.Clear();
            for (var i = 0; i < _data.AmazonItemGroups.Count; i++) _selectedItemIndexes.Add(i);
        }
    }

    private async Task BulkCategorizeAmazonItemsAsync()
    {
        if (_selectedBulkItemCategoryId == 0 || _data is null || _selectedItemIndexes.Count == 0) return;

        var itemIds = _selectedItemIndexes.SelectMany(i => _data.AmazonItemGroups[i].ItemIds).ToList();
        await ReviewQueueProvider.BulkCategorizeAmazonItemsAsync(itemIds, _selectedBulkItemCategoryId);

        _selectedItemIndexes.Clear();
        _lastClickedItemIndex = null;
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }

    private async Task DismissAmazonItemsAsync()
    {
        if (_data is null || _selectedItemIndexes.Count == 0) return;

        var itemIds = _selectedItemIndexes.SelectMany(i => _data.AmazonItemGroups[i].ItemIds).ToList();
        await ReviewQueueProvider.DismissAmazonItemsAsync(itemIds);

        _selectedItemIndexes.Clear();
        _lastClickedItemIndex = null;
        _data = await ReviewQueueProvider.GetReviewQueueAsync();
    }
}
