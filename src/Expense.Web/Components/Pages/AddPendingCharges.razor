@page "/add-pending-charges"
@using Expense.Domain.Services.Categories
@using Expense.Domain.Services.Ingestion.ManualCharges
@using Microsoft.AspNetCore.Components.Forms
@inject IManualChargesPageProvider ChargesProvider
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Add Pending Charges</PageTitle>

<h1>Add Pending Charges</h1>
<p>
    Occasionally screenshot your card's recent activity - including charges still pending, not yet posted - and add
    them here. They'll count toward your forecast right away as their own line, and get cleaned up automatically once
    the real transaction posts and syncs normally.
</p>
<p>Paste a screenshot with Ctrl+V (or Cmd+V) anywhere on this page, or choose a file below.</p>

@if (_accounts is null)
{
    <p>Loading...</p>
}
else
{
    <div>
        <label>Account
            <select id="account-select" @onchange="e => _selectedAccountId = ParseNullableInt((string)e.Value!)">
                <option value="">Select an account...</option>
                @foreach (var account in _accounts)
                {
                    <option value="@account.Id" selected="@(_selectedAccountId == account.Id)">@account.Name</option>
                }
            </select>
        </label>
    </div>
    <div>
        <InputFile id="screenshot-file" OnChange="OnFileSelectedAsync" accept="image/*" />
        <button id="parse-btn" disabled="@(_selectedAccountId is null || _pendingImageBytes is null || _parsing)" @onclick="ParseAsync">
            @(_parsing ? "Reading... (usually 5-15 seconds)" : "Parse Screenshot")
        </button>
    </div>

    @if (_pendingImageSourceLabel is not null)
    {
        <p id="pending-image-label">Image ready: @_pendingImageSourceLabel</p>
    }

    @if (_parseError is not null)
    {
        <p id="parse-error" style="color: #b00020;">Couldn't read that screenshot: @_parseError</p>
    }

    @if (_reviewRows is not null)
    {
        <table id="review-table" style="border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="@CellStyle()"></th>
                    <th style="@CellStyle()">Date</th>
                    <th style="@CellStyle()">Description</th>
                    <th class="text-right" style="@CellStyle(rightAlign: true)">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (row, index) in _reviewRows.Select((r, i) => (r, i)))
                {
                    <tr id="review-row-@index" style="@(_included[index] ? "" : "background-color: #fff3cd;")">
                        <td style="@CellStyle()">
                            <input type="checkbox" id="include-@index" checked="@_included[index]"
                                   @onchange="e => _included[index] = (bool)e.Value!" />
                        </td>
                        <td style="@CellStyle()">
                            <input id="date-@index" type="date" value="@row.Date.ToString("yyyy-MM-dd")"
                                   @onchange="e => row.Date = DateOnly.Parse((string)e.Value!)" />
                        </td>
                        <td style="@CellStyle()">
                            <input id="description-@index" value="@row.Description" style="width: 320px;"
                                   @onchange="e => row.Description = (string)e.Value!" />
                            @if (row.IsDuplicate)
                            {
                                <br />
                                <span style="color: #666;">@row.DuplicateReason</span>
                            }
                        </td>
                        <td class="text-right" style="@CellStyle(rightAlign: true)">
                            <input id="amount-@index" type="number" step="0.01" class="no-spinner amount-input" style="width: 90px;"
                                   value="@row.Amount" @onchange="e => row.Amount = decimal.Parse((string)e.Value!)" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <p><button id="add-all-btn" disabled="@_adding" @onclick="AddAllAsync">Add Selected</button></p>
    }

    @if (_addError is not null)
    {
        <p id="add-error" style="color: #b00020;">Couldn't add those charges: @_addError</p>
    }

    @if (_lastAddedCount is { } addedCount)
    {
        <p id="add-result">Added @addedCount charge(s).</p>
    }
}

@if (_confirmDuplicatesModalOpen)
{
    <div id="confirm-duplicates-modal" style="position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div style="background: var(--color-surface, white); width: 90%; max-width: 600px; padding: 20px; border-radius: 6px;">
            <h2 style="margin-top: 0;">Add charges already in the system?</h2>
            <p>
                @(_duplicateRowsPendingConfirmation.Count == 1 ? "This row is" : $"These {_duplicateRowsPendingConfirmation.Count} rows are")
                selected but already matched to an existing transaction. Adding @(_duplicateRowsPendingConfirmation.Count == 1 ? "it" : "them")
                will create a duplicate.
            </p>
            <ul>
                @foreach (var row in _duplicateRowsPendingConfirmation)
                {
                    <li>@row.Description, $@Math.Abs(row.Amount).ToString("N2") - @row.DuplicateReason</li>
                }
            </ul>
            <p>
                <button id="confirm-add-duplicates-btn" @onclick="ConfirmAddDuplicatesAsync">Add Anyway</button>
                <button id="cancel-add-duplicates-btn" @onclick="CancelAddDuplicates">Cancel</button>
            </p>
        </div>
    </div>
}

@code {
    private List<AccountOption>? _accounts;
    private int? _selectedAccountId;
    private byte[]? _pendingImageBytes;
    private string? _pendingImageContentType;
    private string? _pendingImageSourceLabel;
    private bool _parsing;
    private bool _adding;
    private List<ManualChargeReviewRow>? _reviewRows;
    private List<bool> _included = [];
    private int? _lastAddedCount;
    private string? _parseError;
    private string? _addError;
    private bool _confirmDuplicatesModalOpen;
    private List<ManualChargeReviewRow> _duplicateRowsPendingConfirmation = [];

    private IJSObjectReference? _module;
    private DotNetObjectReference<AddPendingCharges>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await ChargesProvider.GetActiveSpendingAccountsAsync();
        if (_accounts.Count == 1)
        {
            _selectedAccountId = _accounts[0].Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/addPendingCharges.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("registerPasteListener", _dotNetRef);
        }
    }

    private async Task OnFileSelectedAsync(InputFileChangeEventArgs e)
    {
        await using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        SetPendingImage(memoryStream.ToArray(), e.File.ContentType, e.File.Name);
    }

    [JSInvokable]
    public async Task OnImagePasted(IJSStreamReference imageStream, string mediaType)
    {
        using var stream = await imageStream.OpenReadStreamAsync(maxAllowedSize: 10 * 1024 * 1024);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        SetPendingImage(memoryStream.ToArray(), mediaType, "pasted screenshot");
        StateHasChanged();
    }

    private void SetPendingImage(byte[] bytes, string contentType, string sourceLabel)
    {
        _pendingImageBytes = bytes;
        _pendingImageContentType = contentType;
        _pendingImageSourceLabel = sourceLabel;
        _reviewRows = null;
        _lastAddedCount = null;
        _parseError = null;
        _addError = null;
    }

    private async Task ParseAsync()
    {
        if (_selectedAccountId is not { } accountId || _pendingImageBytes is null || _pendingImageContentType is null) return;

        _parsing = true;
        _parseError = null;
        try
        {
            _reviewRows = await ChargesProvider.ReviewScreenshotAsync(accountId, _pendingImageBytes, _pendingImageContentType);
            _included = _reviewRows.Select(r => !r.IsDuplicate).ToList();
            _lastAddedCount = null;
        }
        catch (Exception ex)
        {
            _parseError = ex.Message;
        }
        finally
        {
            _parsing = false;
        }
    }

    private async Task AddAllAsync()
    {
        if (_reviewRows is null) return;

        var acceptedRows = _reviewRows.Where((_, index) => _included[index]).ToList();
        var duplicatesIncluded = acceptedRows.Where(r => r.IsDuplicate).ToList();
        if (duplicatesIncluded.Count > 0)
        {
            _duplicateRowsPendingConfirmation = duplicatesIncluded;
            _confirmDuplicatesModalOpen = true;
            return;
        }

        await PerformAddAsync(acceptedRows);
    }

    private async Task ConfirmAddDuplicatesAsync()
    {
        _confirmDuplicatesModalOpen = false;
        if (_reviewRows is null) return;

        var acceptedRows = _reviewRows.Where((_, index) => _included[index]).ToList();
        await PerformAddAsync(acceptedRows);
    }

    private void CancelAddDuplicates()
    {
        _confirmDuplicatesModalOpen = false;
        _duplicateRowsPendingConfirmation = [];
    }

    private async Task PerformAddAsync(List<ManualChargeReviewRow> acceptedRows)
    {
        if (_selectedAccountId is not { } accountId) return;

        _adding = true;
        _addError = null;
        try
        {
            _lastAddedCount = await ChargesProvider.AddChargesAsync(accountId, acceptedRows);
            _reviewRows = null;
            _included = [];
            _pendingImageBytes = null;
            _pendingImageContentType = null;
            _pendingImageSourceLabel = null;
            _duplicateRowsPendingConfirmation = [];
        }
        catch (Exception ex)
        {
            _addError = ex.Message;
        }
        finally
        {
            _adding = false;
        }
    }

    private static int? ParseNullableInt(string value) => string.IsNullOrEmpty(value) ? null : int.Parse(value);

    private static string CellStyle(bool rightAlign = false) =>
        $"border: 1px solid #ccc; padding: 6px 12px;{(rightAlign ? " text-align: right;" : "")}";

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unregisterPasteListener");
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone (e.g. browser closed/navigated away) - nothing to clean up.
            }
        }

        _dotNetRef?.Dispose();
    }
}
