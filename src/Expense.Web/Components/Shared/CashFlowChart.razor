@using Expense.Domain.Services.Forecast

@{
    var model = Forecast.Rows.Count == 0 ? null : CashFlowChartBuilder.Build(Forecast, Width, Height);
}

@if (model is null)
{
    <p id="cash-flow-chart-empty">No forecast data yet.</p>
}
else
{
    var startBalance = Forecast.StartingBalance;
    var endBalance = Forecast.Rows[^1].RunningBalance;
    var delta = endBalance - startBalance;
    // The trend word comes from the fitted trend line's slope, not simply comparing the first
    // and last raw points - a single early/late spike shouldn't flip the overall reading.
    var trendWord = model.TrendSlopePerDay > 0 ? "up" : model.TrendSlopePerDay < 0 ? "down" : "flat";

    <p id="cash-flow-trend-summary">
        Trending @trendWord: @startBalance.ToString("N2") &rarr; @endBalance.ToString("N2")
        (@(delta >= 0 ? "+" : "")@delta.ToString("N2"))
    </p>
    <p>
        <label>
            <input type="checkbox" id="cash-flow-chart-toggle-raw-line" checked="@_showRawLine"
                   @onchange="e => _showRawLine = (bool)e.Value!" />
            Daily balance
        </label>
        <label style="margin-left: 1em;">
            <input type="checkbox" id="cash-flow-chart-toggle-trend-line" checked="@_showTrendLine"
                   @onchange="e => _showTrendLine = (bool)e.Value!" />
            Straight trend
        </label>
        <label style="margin-left: 1em;">
            <input type="checkbox" id="cash-flow-chart-toggle-moving-average" checked="@_showMovingAverage"
                   @onchange="e => _showMovingAverage = (bool)e.Value!" />
            30-day average
        </label>
    </p>
    <svg id="cash-flow-chart-svg" viewBox="0 0 @(model.Width) @(model.Height + 25)" width="100%"
         style="max-width: 100%; border: 1px solid var(--color-text-muted, #64748b); background: var(--color-surface, #fff); box-sizing: border-box; padding: 4px; border-radius: 4px;">
        @foreach (var tick in model.YAxisTicks)
        {
            <line x1="@CashFlowChartBuilder.LeftAxisMargin" y1="@tick.Y" x2="@model.Width" y2="@tick.Y" stroke="#eee" stroke-width="1" />
            @TextElement(CashFlowChartBuilder.LeftAxisMargin - 6, tick.Y + 4, "#666", "end", tick.Label)
        }

        <line x1="@CashFlowChartBuilder.LeftAxisMargin" y1="@model.ZeroLineY" x2="@model.Width" y2="@model.ZeroLineY"
              stroke="#999" stroke-dasharray="4,3" stroke-width="1" />
        @TextElement(CashFlowChartBuilder.LeftAxisMargin - 6, model.ZeroLineY + 4, "#999", "end", "0")

        @foreach (var tick in model.MonthTicks)
        {
            <line x1="@tick.X" y1="0" x2="@tick.X" y2="@model.Height" stroke="#eee" stroke-width="1" />
            @TextElement(tick.X, model.Height + 16, "#666", "middle", tick.Label)
        }

        @if (_showTrendLine)
        {
            <line x1="@model.TrendLineStart.X" y1="@model.TrendLineStart.Y" x2="@model.TrendLineEnd.X" y2="@model.TrendLineEnd.Y"
                  id="cash-flow-chart-trend-line" stroke="#c05621" stroke-width="2" stroke-dasharray="6,3" />
        }

        @if (_showMovingAverage)
        {
            <polyline id="cash-flow-chart-moving-average-line" fill="none" stroke="#2f855a" stroke-width="2"
                      points="@string.Join(" ", model.MovingAveragePoints.Select(p => $"{p.X:F1},{p.Y:F1}"))" />
        }

        @if (_showRawLine)
        {
            <polyline id="cash-flow-chart-line" fill="none" stroke="#8ab4d8" stroke-width="1.25"
                      points="@string.Join(" ", model.Points.Select(p => $"{p.X:F1},{p.Y:F1}"))" />

            @if (model.LowestPoint is { } lowest)
            {
                <circle id="cash-flow-chart-lowest-marker" cx="@lowest.X" cy="@lowest.Y" r="4" fill="#b00020" />
                @TextElement(lowest.X, lowest.Y - 8, "#b00020", model.LowestPointAnchor, $"{lowest.Balance:N2} on {lowest.Date:MM/dd/yyyy}")
            }
        }
    </svg>
}

@code {
    [Parameter, EditorRequired]
    public required ForecastResult Forecast { get; set; }

    [Parameter]
    public int Width { get; set; } = 800;

    [Parameter]
    public int Height { get; set; } = 260;

    private bool _showRawLine = true;
    private bool _showTrendLine = true;
    private bool _showMovingAverage = true;

    // Razor's parser reserves the literal <text>/</text> tag pair for its own "output literal
    // text" directive (case-insensitively), which collides with SVG's <text> element and
    // can't be written directly in markup - emitting it as a raw string sidesteps that entirely.
    private static MarkupString TextElement(double x, double y, string fill, string anchor, string content) =>
        (MarkupString)$"""<text x="{x:F1}" y="{y:F1}" font-size="11" fill="{fill}" text-anchor="{anchor}">{System.Net.WebUtility.HtmlEncode(content)}</text>""";
}
