<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
    <ProjectReference Include="..\Expense.Domain\Expense.Domain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Same source file the SimpleFin console importer uses - kept in one place so the
         Dashboard's "Sync Now" button reads the exact same account mapping. -->
    <None Include="..\Expense.Importers.SimpleFin\simplefin-account-map.json" Link="simplefin-account-map.json"
          CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\Expense.Importers.SimpleFin\simplefin-account-map.json')" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <UserSecretsId>0db5d028-68d5-4f98-9331-6365b8bf6ce1</UserSecretsId>
  </PropertyGroup>

</Project>
